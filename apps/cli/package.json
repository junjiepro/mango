{
  "name": "mango-ai-cli",
  "version": "0.1.1",
  "type": "module",
  "description": "Mango CLI - 智能 Agent 对话平台设备服务",
  "bin": {
    "mango-ai-cli": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "build:standalone": "tsup src/index.ts --format esm --minify --clean",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist",
    "package": "pnpm build:standalone && node scripts/package.js",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.13.0",
    "@hono/mcp": "^0.2.2",
    "@hono/node-server": "^1.5.0",
    "@mcpc-tech/acp-ai-provider": "^0.2.4",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@supabase/supabase-js": "^2.39.0",
    "@types/ws": "^8.18.1",
    "ai": "^6.0.30",
    "axios": "^1.6.2",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "fetch-to-node": "^2.1.0",
    "hono": "^4.11.1",
    "inquirer": "^9.2.12",
    "node-pty": "^1.1.0",
    "open": "^10.0.3",
    "ora": "^8.0.1",
    "ws": "^8.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
