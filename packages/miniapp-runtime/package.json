{
  "name": "@mango/miniapp-runtime",
  "version": "0.1.0",
  "description": "MiniApp runtime and sandbox for Mango platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./apis": {
      "types": "./dist/apis/index.d.ts",
      "import": "./dist/apis/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest"
  },
  "dependencies": {
    "@mango/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^1.0.4",
    "jsdom": "^23.0.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  },
  "keywords": [
    "miniapp",
    "sandbox",
    "runtime",
    "iframe",
    "security"
  ],
  "author": "Mango Team",
  "license": "MIT"
}
